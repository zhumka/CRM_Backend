# HTTP
HTTP_PORT=8080
GIN_MODE=debug

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=crm
DB_PASSWORD=crm
DB_NAME=crm
DB_SSLMODE=disable

# JWT (обязательно укажите секрет!)
JWT_SECRET=change-me-in-production
JWT_TTL_HOURS=24

# Администратор по умолчанию (создаётся при первом запуске)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Наполнять БД демо-данными при первом запуске (true/false)
SEED_DEMO=true

